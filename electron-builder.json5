/**
 * @see https://www.electron.build/configuration/configuration
 */
{
  appId: "com.codedesyntax.bookofredemption",
  productName: "Bible Book-Of-Redemption",
  asar: true,
  directories: {
    output: "release/${version}",
  },
  files: ["dist-electron", "dist", ".env"],
  icon: "public/bibleicon.ico",

  win: {
    target: [
      {
        target: "nsis",
        arch: ["x64"],
      },
    ],
    artifactName: "BOR_${version}.${ext}",
    icon: "public/bibleicon.ico",
  },
  nsis: {
    oneClick: false,
    perMachine: false,
    allowToChangeInstallationDirectory: true,
    deleteAppDataOnUninstall: false,
    installerIcon: "public/bibleicon.ico",
    uninstallerIcon: "public/bibleicon.ico",
    installerHeaderIcon: "public/bibleicon.ico",
  },
  publish: {
    provider: "github",
    owner: "codeDeSyntax",
    repo: "Bible-App",
    releaseType: "release",
  },
}
